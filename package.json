{
	"name": "rjp-portfolio",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "next dev",
		"build": "next build",
		"start": "next start",
		"typecheck": "tsc --noEmit",
		"lint": "eslint . && biome check .",
		"lint:eslint": "eslint .",
